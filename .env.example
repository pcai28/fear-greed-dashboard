# The waitlist stays closed unless both backend and frontend flags are enabled.
WAITLIST_ENABLED=0
VITE_WAITLIST_ENABLED=0

# Cloudflare Turnstile: the secret stays backend-only; the site key is intentionally public.
# Use real Managed-widget keys and the exact public hostname before enabling the waitlist.
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
VITE_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
TURNSTILE_EXPECTED_HOSTNAME=market.example.com
TURNSTILE_EXPECTED_ACTION=waitlist

# RATE_LIMIT_HMAC_SECRET is required for every production API runtime. The remaining
# values are also required before enabling the waitlist. Never put real secrets here.
PRIVACY_CONTROLLER_NAME="Your legal name or registered company name"
VITE_PRIVACY_CONTROLLER_NAME="Your legal name or registered company name"
PRIVACY_CONTACT_EMAIL=privacy@example.com
VITE_PRIVACY_CONTACT_EMAIL=privacy@example.com
# Not required to collect waitlist signups; configure before sending the launch email.
BUSINESS_POSTAL_ADDRESS="Registered business postal address"
APP_REGION=us-west-provider-region
MONGODB_REGION=us-west-provider-region
UPSTASH_REGION=us-west-provider-region
TRUSTED_PROXY_HOPS=0
CLIENT_IP_HEADER=x-forwarded-for
RATE_LIMIT_HMAC_SECRET=replace-with-a-long-random-secret

MONGODB_URI=mongodb+srv://username:password@example.mongodb.net/
MONGODB_DB=market_emotions
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-secret
